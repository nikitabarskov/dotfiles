brew-clean() {
    setopt localoptions rmstarsilent
    local cache
    local -a cache_entries

    cache=$(brew --cache)
    brew autoremove && \
    brew bundle cleanup --force --global && \
    brew cleanup --prune=all --scrub || return

    cache_entries=("$cache"/*(DN))
    if (( ${#cache_entries} )); then
        du -sh -- "${cache_entries[@]}" && \
        rm -vrf -- "${cache_entries[@]}"
    fi
}

brew-add() {
    brew install "$@" && \
    brew bundle --verbose --global add "$@"
}

brew-remove() {
    brew uninstall "$@" && \
    brew bundle --verbose --global remove "$@"
}

brew-install() {
    brew bundle install --global --verbose
}

brew-lock() {
    brew bundle dump --force --verbose --global
}

brew-upgrade() {
    brew update && \
    brew upgrade && \
    brew bundle install --global --upgrade --verbose && \
    brew-clean
}

macos-u() {
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    sudo softwareupdate \
        --install \
        --all \
        --agree-to-license \
        --force \
        --restart
    rm /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
}

macos-clt() {
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    local clt_label
    clt_label=$(softwareupdate --list 2>/dev/null | grep "Command Line Tools" | grep "Label:" | awk -F'Label: ' '{print $2}' | head -n 1)
    if [[ -n "$clt_label" ]]; then
        echo "Installing $clt_label..."
        sudo softwareupdate --install --agree-to-license --verbose --force "$clt_label"
    fi
    rm /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
}

nb() {
    local date
    date=$(date +%Y%m%dT%H%M%S)
    echo "nikita.barskov-$date-$1"
}

avb() {
    av branch "nikita.barskov-$(date +%Y%m%dT%H%M%S)-$1"
}

avsc() {
    av sync --rebase-to-trunk --current
}

avs() {
    av sync --rebase-to-trunk
}

avpr() {
    av pr --draft
}

alias jg='just --global-justfile'
alias sem="$(cd "$HOME" && mise which sem)"
