{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "inspect_*": "allow",
    "sem_*": "allow",
    "codegraph_*": "allow",
    "headroom_*": "allow",
  },
  "mcp": {
    "codegraph": {
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
      "type": "local",
    },
    "sem": {
      "command": ["sem-mcp"],
      "enabled": true,
      "type": "local",
    },
    "inspect": {
      "command": ["inspect-mcp"],
      "enabled": true,
      "type": "local",
    },
    "headroom": {
      "command": ["headroom", "mcp", "serve"],
      "enabled": true,
      "type": "local",
    },
  },
}
